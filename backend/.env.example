# Banco de dados
# Se DATABASE_URL nao for definido, o backend usa SQLite local em backend/data/study_hub.db
# DATABASE_URL=sqlite:///D:/caminho/para/study_hub.db
# DATABASE_URL=postgresql+psycopg://postgres:senha@db.xxx.supabase.co:5432/postgres
# Para usar Supabase/Postgres como banco principal do backend, defina DATABASE_URL
# e rode o bootstrap:
# python -m app.bootstrap_postgres --include-usage

STUDY_HUB_DB_ECHO=false
# Em Postgres, o default e true. Em SQLite, o default e false.
# STUDY_HUB_AUTO_SYNC_STRUCTURAL_ON_STARTUP=true

# Frontend local + deploy Vercel
# STUDY_HUB_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://SEU-APP.vercel.app

# Exemplo de env para deploy do backend no Render com banco Postgres/Supabase:
# DATABASE_URL=postgresql+psycopg://postgres:senha@db.xxx.supabase.co:5432/postgres
# STUDY_HUB_MACHINE_PROFILE=notebook
# STUDY_HUB_LLM_ENABLED=false
# STUDY_HUB_ESSAY_CORRECTION_ENABLED=false
# STUDY_HUB_ESSAY_STUDY_ENABLED=false
# STUDY_HUB_DB_ECHO=false
# STUDY_HUB_CORS_ORIGINS=https://SEU-APP.vercel.app,http://localhost:5173

# Feature flags / perfil de maquina
# local e o default se nada for definido
# STUDY_HUB_MACHINE_PROFILE=desktop
# STUDY_HUB_MACHINE_PROFILE=notebook
# STUDY_HUB_MACHINE_PROFILE=local

# Se nao definido:
# - desktop/local: true
# - notebook: false
# STUDY_HUB_LLM_ENABLED=true
# STUDY_HUB_LLM_ENABLED=false

# Se nao definidos, seguem o valor efetivo de STUDY_HUB_LLM_ENABLED
# STUDY_HUB_ESSAY_CORRECTION_ENABLED=true
# STUDY_HUB_ESSAY_CORRECTION_ENABLED=false
# STUDY_HUB_ESSAY_STUDY_ENABLED=true
# STUDY_HUB_ESSAY_STUDY_ENABLED=false

# Provider local padrao
STUDY_HUB_LLM_PROVIDER=lm_studio

# Modelo principal desta fase
STUDY_HUB_LLM_MODEL=gemma-4-e4b

# LM Studio em modo servidor local OpenAI-compatible
STUDY_HUB_LLM_BASE_URL=http://127.0.0.1:1234/v1

# Timeout base de fallback
STUDY_HUB_LLM_TIMEOUT_SECONDS=30

# Timeouts por tarefa
STUDY_HUB_LLM_TIMEOUT_QUESTION_EXPLAIN_TEXT_SECONDS=25
STUDY_HUB_LLM_TIMEOUT_ESSAY_SCORE_SECONDS=60
STUDY_HUB_LLM_TIMEOUT_ESSAY_DETAILED_SECONDS=90
STUDY_HUB_LLM_TIMEOUT_ESSAY_TEACH_SECONDS=105

# Opcional. Em LM Studio normalmente pode ficar vazio.
# STUDY_HUB_LLM_API_KEY=lm-studio
